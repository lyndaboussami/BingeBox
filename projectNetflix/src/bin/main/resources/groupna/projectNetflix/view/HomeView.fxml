<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" styleClass="scroll" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="groupna.projectNetflix.controllers.HomeViewController">
    <VBox spacing="40" styleClass="main-container">
        <StackPane fx:id="heroSection" styleClass="hero" onMouseEntered="#playTrailer" onMouseExited="#stopTrailer">
            <MediaView fx:id="trailerVideo" preserveRatio="false" opacity="1.0" />
            
            <VBox spacing="10" alignment="CENTER_LEFT" mouseTransparent="true">
                <padding><Insets left="40" bottom="30"/></padding>
                
                <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="%hero.release" styleClass="meta-tag"/>
                     <Label text="1h53" styleClass="meta-tag"/>
                     <Label text="2026" styleClass="meta-tag"/>
                     <Label text="%cat.action_drama" styleClass="meta-tag"/>
                </HBox>

                <Label fx:id="heroTitle" text="%movie.3.title" styleClass="heroTitle"/>
                <Label fx:id="heroDesc" text="%movie.3.desc" styleClass="hero-desc-responsive" wrapText="true" maxWidth="450"/>

                <Button text="%btn.watch_now" styleClass="watchBtn"/>
            </VBox>
        </StackPane>

        <VBox spacing="10" styleClass="category-section">
            <Label fx:id="selectionTitle" text="%label.selection" styleClass="categoryTitle"/>
            <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="inner-scroll">
                <HBox fx:id="moviesRow" spacing="15">
                    <padding><Insets left="20" right="20"/></padding>
                </HBox>
            </ScrollPane>
        </VBox>
        
        <VBox spacing="10" styleClass="category-section">
            <Label fx:id="recommendedTitle" text="%label.recommended" styleClass="categoryTitle"/>
            <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="inner-scroll">
                <HBox fx:id="seriesRow" spacing="15">
                    <padding><Insets left="20" right="20"/></padding>
                </HBox>
            </ScrollPane>
        </VBox>

        <Region prefHeight="100"/>
    </VBox>
</ScrollPane>