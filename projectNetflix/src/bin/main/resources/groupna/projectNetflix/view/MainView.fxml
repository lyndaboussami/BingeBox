<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.media.*?>
<?import javafx.collections.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="groupna.projectNetflix.controllers.MainViewController"
            stylesheets="@../css/style.css"
            styleClass="root">

	<left>
        <VBox spacing="25" styleClass="sidebar">
            <padding>
                <Insets top="30" left="15" right="15"/>
            </padding>
            
            <Button onAction="#handleProfile" styleClass="sidebar-profile-btn">
                <graphic>
                    <Circle radius="20" fill="#CFB997"/>
                </graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" /> <Button onAction="#handleSearch" styleClass="sidebar-icon-btn" text="🔍" />
            <Button onAction="#handleHome" styleClass="sidebar-icon-btn" text="🏠" />
            <Button onAction="#handleSeries" styleClass="sidebar-icon-btn" text="📺" />
            <Button onAction="#handleMovies" styleClass="sidebar-icon-btn" text="🎬" />
            <Button onAction="#handleFavorites" styleClass="sidebar-icon-btn" text="🔖" />
            <Button onAction="#handleHistory" styleClass="sidebar-icon-btn" text="🕒" />
            
            <Region VBox.vgrow="ALWAYS" />

            <Button onAction="#handleSettings" styleClass="sidebar-icon-btn" text="⛯" />
        </VBox>
    </left>
    <top>
        <HBox fx:id="navbar" alignment="CENTER" spacing="10" styleClass="navbar">
        
        	<HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
        		<Label styleClass="logo" text="BingeBox" />
    		</HBox>	
    		
    		<Region HBox.hgrow="ALWAYS" /> 
    		
    		<HBox alignment="CENTER" spacing="10">		
				<Button fx:id="homeBtn" text="Home" onAction="#goHome" styleClass="navButton"/>
				<Button fx:id="moviesBtn" text="Movies" onAction="#openMovies" styleClass="navButton"/>
				<Button fx:id="seriesBtn" text="Series" onAction="#openSeries" styleClass="navButton"/>
			</HBox>
			<Region HBox.hgrow="ALWAYS" /> 
			
            <padding>
                <Insets top="10" bottom="10" left="25" right="25"/>
            </padding>

            <ComboBox fx:id="languageSelector" styleClass="language-picker">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="🇺🇸 English" />
                        <String fx:value="🇫🇷 Français" />
                        <String fx:value="🇹🇳 Tunisian" />
                    </FXCollections>
                </items>
                <value>
                    <String fx:value="🇺🇸 English" />
                </value>
            </ComboBox>

            <TextField promptText="Search movies..." styleClass="search"/>
            
            <Button fx:id="themeToggle" onAction="#handleThemeChange" styleClass="theme-patch">
                <graphic>
                    <Label text="🔀" styleClass="theme-label" /> 
                </graphic>
            </Button>
            <HBox alignment="CENTER_RIGHT" styleClass="window-controls">
		        <Button onAction="#handleMinimize" text="—" styleClass="control-btn" />
		        <Button onAction="#handleMaximize" text="▢" styleClass="control-btn" />
		        <Button onAction="#handleClose" text="✕" styleClass="control-btn, close-btn" />
		    </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll">
            <VBox spacing="40" styleClass="main-container">
                <StackPane fx:id="heroSection" 
			           styleClass="hero" 
			           onMouseEntered="#playTrailer" 
			           onMouseExited="#stopTrailer">
			
				    <MediaView fx:id="trailerVideo" preserveRatio="false" opacity="1.0" />
				
				    <VBox spacing="10" alignment="CENTER_LEFT" mouseTransparent="true">
				        <padding>
				            <Insets left="40" bottom="30"/>
				        </padding>
				        
				        <HBox spacing="10" alignment="CENTER_LEFT">
				             <Label text="Release on April 10, 2026" styleClass="meta-tag"/>
				             <Label text="1h53" styleClass="meta-tag"/>
				             <Label text="2026" styleClass="meta-tag"/>
				             <Label text="Sports, Action, Drama" styleClass="meta-tag"/>
				        </HBox>
				
				        <Label fx:id="heroTitle" text="BEAST" styleClass="heroTitle"/>
				        
				        <Label fx:id="heroDesc" styleClass="hero-desc-responsive"
				               text="MMA legend Patton James, now a commercial fisherman, is pulled back into the cage when his brother is in danger. Reuniting with his old coach Sammy, he commits to one final fight in ONE Championship against its champion Xavier Grau." 
				               wrapText="true" maxWidth="450"/>
				
				        <Button text="Watch Now ▷" styleClass="watchBtn"/>
			    </VBox>
			    
			</StackPane>
                <VBox spacing="10" styleClass="category-section">
                    <Label fx:id="selectionTitle" text="Selection" styleClass="categoryTitle"/>
                    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="inner-scroll">
                        <HBox spacing="15">
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Movie 1" styleClass="card-text"/>
                            </VBox>
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Movie 2" styleClass="card-text"/>
                            </VBox>
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Movie 3" styleClass="card-text"/>
                            </VBox>
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Movie 4" styleClass="card-text"/>
                            </VBox>
                        </HBox>
                    </ScrollPane>
                </VBox>

                <VBox spacing="10" styleClass="category-section">
                    <Label fx:id="recommendedTitle" text="Recommended For You" styleClass="categoryTitle"/>
                    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="inner-scroll">
                        <HBox spacing="15">
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Series A" styleClass="card-text"/>
                            </VBox>
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Series B" styleClass="card-text"/>
                            </VBox>
                            <VBox styleClass="movieCard" onMouseEntered="#showDetails" onMouseExited="#hideDetails">
                                <Rectangle width="140" height="200" styleClass="poster-placeholder"/>
                                <Label text="Series C" styleClass="card-text"/>
                            </VBox>
                        </HBox>
                    </ScrollPane>
                </VBox>

                <Region prefHeight="100"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>