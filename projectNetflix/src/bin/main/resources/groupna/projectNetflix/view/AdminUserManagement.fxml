<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="groupna.projectNetflix.controllers.AdminUserController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Comment Moderation" styleClass="heroTitle" style="-fx-font-size: 26px;"/>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="commentSearchField" promptText="Search by user or content..." prefWidth="300" styleClass="search-bar"/>
    </HBox>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="Reported Content" styleClass="categoryTitle" style="-fx-padding: 0;"/>
        
        <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
		        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
		    </columnResizePolicy>
		    
            <columns>
                <TableColumn fx:id="colUser" text="User ID" prefWidth="70"/>
                <TableColumn fx:id="colOeuvre" text="Media ID" prefWidth="70"/>
                <TableColumn fx:id="colComment" text="Comment Content" prefWidth="400"/>
                <TableColumn fx:id="colReason" text="Report Reason" prefWidth="200"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No reported comments found." styleClass="card-text"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>