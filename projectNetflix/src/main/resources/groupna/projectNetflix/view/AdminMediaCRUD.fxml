<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<VBox spacing="20" style="-fx-background-color: -fx-primary-bg;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="groupna.projectNetflix.controllers.AdminMediaController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Content Management Dashboard" styleClass="heroTitle" style="-fx-font-size: 26px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="🔍 Search by title, genre, or ID..." prefWidth="350" styleClass="search-bar"/>
    </HBox>

    <TabPane styleClass="admin-table" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        
        <Tab text="🎬 Movies" styleClass="navButton">
            <VBox spacing="10" style="-fx-padding: 15 0 0 0;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add New Movie" onAction="#showMovieForm" styleClass="watchBtn"/>
                </HBox>
                <TableView fx:id="movieTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                	<columnResizePolicy>
				        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
				    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colMovieThumb" text="Poster" prefWidth="80" />
                        <TableColumn fx:id="colMovieTitle" text="Title" prefWidth="250" />
                        <TableColumn fx:id="colMovieDate" text="Release" prefWidth="120" />
                        <TableColumn fx:id="colMovieDuration" text="Duration" prefWidth="100" />
                        <TableColumn fx:id="colMovieActions" text="Actions" prefWidth="150" />
                    </columns>
                    <placeholder>
                		<Label text="No reported comments found." styleClass="card-text"/>
            		</placeholder>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="📺 TV Series" styleClass="navButton">
            <VBox spacing="10" style="-fx-padding: 15 0 0 0;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add New Series" onAction="#showSerieForm" styleClass="watchBtn"/>
                </HBox>
                <TableView fx:id="serieTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                    <columnResizePolicy>
				        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
				    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colSerieThumb" text="Poster" prefWidth="80" />
                        <TableColumn fx:id="colSerieTitle" text="Title" prefWidth="250" />
                        <TableColumn fx:id="colSerieDate" text="Release" prefWidth="120" />
                        <TableColumn fx:id="colSerieSeasons" text="Seasons" prefWidth="100" />
                        <TableColumn fx:id="colSerieActions" text="Actions" prefWidth="150" />
                    </columns>
                    <placeholder>
                		<Label text="No reported comments found." styleClass="card-text"/>
            		</placeholder>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>