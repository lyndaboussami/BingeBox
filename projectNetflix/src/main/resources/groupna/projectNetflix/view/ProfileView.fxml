<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<VBox alignment="CENTER" spacing="30" styleClass="main-container" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="groupna.projectNetflix.controllers.ProfileViewController">
    <padding>
        <Insets top="50" bottom="50"/>
    </padding>

    <Label text="Who's watching?" style="-fx-font-size: 40px; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="40">
        <VBox alignment="CENTER" spacing="15" styleClass="profile-card">
            <StackPane styleClass="profile-avatar-container">
                <Rectangle width="150" height="150" arcWidth="20" arcHeight="20" fill="#CFB997" stroke="WHITE" strokeWidth="2"/>
                <Label text="👤" style="-fx-font-size: 60px;"/>
            </StackPane>
            <Label text="User Name" style="-fx-font-size: 18px; -fx-text-fill: #E5E5E5;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="15" styleClass="profile-card">
            <StackPane styleClass="profile-avatar-container">
                <Rectangle width="150" height="150" arcWidth="20" arcHeight="20" fill="#2ECC71"/>
                <Label text="🎈" style="-fx-font-size: 60px;"/>
            </StackPane>
            <Label text="Kids" style="-fx-font-size: 18px; -fx-text-fill: #E5E5E5;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="15" styleClass="profile-card">
            <StackPane styleClass="profile-avatar-container">
                <Rectangle width="150" height="150" arcWidth="20" arcHeight="20" fill="transparent" stroke="#808080" strokeDashArray="10"/>
                <Label text="+" style="-fx-font-size: 50px; -fx-text-fill: #808080;"/>
            </StackPane>
            <Label text="Add Profile" style="-fx-font-size: 18px; -fx-text-fill: #808080;"/>
        </VBox>
    </HBox>

</VBox>