<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="groupna.projectNetflix.controllers.AdminUserController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Comment Moderation" styleClass="heroTitle" style="-fx-font-size: 26px;"/>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="commentSearchField" promptText="Search by user or content..." prefWidth="300" styleClass="search-bar"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="admin-tab-pane">
	    <Tab text="🎬 Movie Reports" styleClass="navButton">
	        <VBox spacing="10" style="-fx-padding: 15;">
	            <TableView fx:id="movieReportsTable" VBox.vgrow="ALWAYS">
	                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
	                <columns>
	                    <TableColumn fx:id="colMovieUser" text="User ID" prefWidth="100"/>
	                    <TableColumn fx:id="colMovieId" text="Movie ID" prefWidth="100"/>
	                    <TableColumn fx:id="colMovieComment" text="Comment" prefWidth="400"/>
	                    <TableColumn fx:id="colMovieReason" text="Reason" prefWidth="200"/>
	                    <TableColumn fx:id="colMovieActions" text="Actions" prefWidth="200"/>
	                </columns>
	            </TableView>
	        </VBox>
	    </Tab>
	
	    <Tab text="📺 Series Reports" styleClass="navButton">
	        <VBox spacing="10" style="-fx-padding: 15;">
	            <TableView fx:id="serieReportsTable" VBox.vgrow="ALWAYS">
	                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
	                <columns>
	                    <TableColumn fx:id="colSerieUser" text="User ID" prefWidth="100"/>
	                    <TableColumn fx:id="colSerieId" text="Series ID" prefWidth="100"/>
	                    <TableColumn fx:id="colSerieComment" text="Comment" prefWidth="400"/>
	                    <TableColumn fx:id="colSerieReason" text="Reason" prefWidth="200"/>
	                    <TableColumn fx:id="colSerieActions" text="Actions" prefWidth="200"/>
	                </columns>
	            </TableView>
	        </VBox>
	    </Tab>
	</TabPane>
</VBox>