<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.media.*?>
<?import javafx.collections.*?>
<?import java.lang.String?>

<StackPane fx:id="mainStack" 
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="groupna.projectNetflix.controllers.MainViewController"
           stylesheets="@../css/style.css"
           styleClass="root">

    <BorderPane fx:id="rootPane">
		<left>
	        <VBox spacing="20" fx:id="sidebar" styleClass="sidebar" prefWidth="70" minWidth="70">
	            <padding>
	                <Insets top="30" left="10" right="10"/>
	            </padding>
	            
				<StackPane styleClass="profile-container" onMouseClicked="#handleProfileClick">
				    <padding><Insets top="20" bottom="20"/></padding>
				    <Label text="👤" styleClass="profile-icon" />
				</StackPane>
	
	            <Region VBox.vgrow="ALWAYS" /> <Button onAction="#handleSearch" styleClass="sidebar-icon-btn" text="🔍" />
	            <Button onAction="#goHome" styleClass="sidebar-icon-btn" text="🏠" />
	            <Button onAction="#openSeries" styleClass="sidebar-icon-btn" text="📺" />
	            <Button onAction="#openMovies" styleClass="sidebar-icon-btn" text="🎬" />
	            <Button onAction="#handleFavorites" styleClass="sidebar-icon-btn" text="❤" />
	            <Button onAction="#handleHistory" styleClass="sidebar-icon-btn" text="🕒" />
	            
	            <Region VBox.vgrow="ALWAYS" />
	
	            <Button onAction="#handleSettings" styleClass="sidebar-icon-btn" text="⛯" />
	        
		        <Separator prefWidth="150.0" styleClass="admin-separator" />
	    			
			    <Button fx:id="btnManageContent" text="🛠️" 
			            styleClass="admin-nav-button" onAction="#handleAdminNav" />
			            
			    <Button fx:id="btnManageUsers" text="👥" 
			            styleClass="admin-nav-button" onAction="#handleAdminNav" />
			            
			    <Button fx:id="btnAnalytics" text="📊" 
			            styleClass="admin-nav-button" onAction="#handleAdminNav" />
	        </VBox>
	    </left>
	    <top>
		    <HBox fx:id="navbar" alignment="CENTER_LEFT" styleClass="navbar">
		        <padding>
		            <Insets top="0" bottom="0" left="25" right="0"/> </padding>
		
		        <HBox alignment="CENTER_LEFT" minWidth="200"> 
		            <Label styleClass="logo" text="BingeBox"/>
		        </HBox>
		
		        <Region HBox.hgrow="ALWAYS" />
		
		        <HBox fx:id="navLinksContainer" alignment="CENTER" spacing="25">
		            <Button fx:id="homeBtn" text="Home" onAction="#goHome" styleClass="navButton"/>
		            <Button fx:id="moviesBtn" text="Movies" onAction="#openMovies" styleClass="navButton"/>
		            <Button fx:id="seriesBtn" text="Series" onAction="#openSeries" styleClass="navButton"/>
		        </HBox>
		
		        <Region HBox.hgrow="ALWAYS" />
		
		        <HBox alignment="CENTER_RIGHT" spacing="15" minWidth="200">
		            <ComboBox fx:id="languageSelector" styleClass="language-picker">
		                <items>
		                    <FXCollections fx:factory="observableArrayList">
		                        <String fx:value="🇺🇸 English" />
		                        <String fx:value="🇫🇷 Français" />
		                        <String fx:value="🇹🇳 Tunisian" />
		                    </FXCollections>
		                </items>
		                <value>
		                    <String fx:value="🇺🇸 English" />
		                </value>
		            </ComboBox>
		            
		            <Button fx:id="themeToggle" onAction="#handleThemeChange" styleClass="theme-patch">
		                <graphic>
		                    <Label text="🔀" styleClass="theme-label" /> 
		                </graphic>
		            </Button>
		
		            <HBox alignment="CENTER_RIGHT" styleClass="window-controls">
		                <Button onAction="#handleMinimize" text="—" styleClass="control-btn" />
		                <Button onAction="#handleMaximize" text="▢" styleClass="control-btn" />
		                <Button onAction="#handleClose" text="✕" styleClass="control-btn, close-btn" />
		            </HBox>
		        </HBox>
		    </HBox>
		</top>
	    <center/>
	</BorderPane>
</StackPane>