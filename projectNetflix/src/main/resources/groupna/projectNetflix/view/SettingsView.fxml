<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="groupna.projectNetflix.controllers.SettingsViewController">
    <VBox spacing="30" fillWidth="true" maxWidth="Infinity" styleClass="main-container"> 
        <padding>
            <Insets top="40" bottom="40" left="60" right="60"/>
        </padding>

        <Label text="Account Settings" style="-fx-font-size: 32px;"/> 

        <VBox spacing="20" styleClass="auth-container" style="-fx-padding: 30;">
            <Label text="Personal Information" style="-fx-font-size: 20px; -fx-text-fill: -fx-accent;"/>
            
            <GridPane hgap="30" vgap="20">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="150"/>
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="First Name:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="firstNameField" styleClass="auth-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Last Name:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="lastNameField" styleClass="auth-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Email Address:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" styleClass="auth-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>
            
            <Button text="Update Profile" onAction="#handleUpdateProfile" styleClass="watchBtn" style="-fx-padding: 10 20;"/>
        </VBox>

        <VBox spacing="20" styleClass="auth-container" style="-fx-padding: 30;">
            <Label text="Security" style="-fx-font-size: 20px; -fx-text-fill: -fx-accent;"/>
            
            <VBox spacing="15">
                <VBox spacing="5">
                    <Label text="Current Password" style="-fx-text-fill: -fx-text-muted;"/>
                    <PasswordField fx:id="oldPasswordField" styleClass="auth-field"/>
                </VBox>
                
                <Separator opacity="0.1" />
                
                <HBox spacing="20">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="New Password" style="-fx-text-fill: -fx-text-muted;"/>
                        <PasswordField fx:id="newPasswordField" styleClass="auth-field"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Confirm New Password" style="-fx-text-fill: -fx-text-muted;"/>
                        <PasswordField fx:id="confirmPasswordField" styleClass="auth-field"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Change Password" onAction="#handleUpdatePassword" styleClass="watchBtn" style="-fx-padding: 10 20;"/>
                <Label fx:id="statusLabel" />
            </HBox>
        </VBox>

		<VBox spacing="20" styleClass="auth-container" style="-fx-padding: 30; -fx-border-color: #ff6b6b; -fx-border-width: 1; -fx-border-radius: 5;">
		    <Label text="Danger Zone" style="-fx-font-size: 20px; -fx-text-fill: #ff6b6b;"/>
		    <Button text="Delete Account" onAction="#handleDeleteAccount" 
		            style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
		    <Label text="Once you delete your account, there is no going back. Please be certain." 
		           style="-fx-text-fill: -fx-text-muted;" wrapText="true"/>
		    
		    </VBox>

    </VBox>
</ScrollPane>