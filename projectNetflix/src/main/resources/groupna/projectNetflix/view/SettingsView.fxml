<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" styleClass="scroll" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="groupna.projectNetflix.controllers.SettingsViewController">
    <VBox spacing="30" styleClass="main-container">
        <padding>
            <Insets top="40" bottom="40" left="60" right="60"/>
        </padding>

        <Label text="Settings" style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Separator opacity="0.2" />

        <VBox spacing="20" styleClass="settings-section">
            <Label text="Account Details" style="-fx-font-size: 18px; -fx-text-fill: #E5E5E5; -fx-font-weight: bold;"/>
            
            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="150" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Username" style="-fx-text-fill: #f2f0f0;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" text="User_BingeBox" styleClass="search" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Email" style="-fx-text-fill: #f2f0f0;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" text="user@example.com" styleClass="search" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Password" style="-fx-text-fill: #f2f0f0;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField" text="********" styleClass="search" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>
            
            <Button text="Save Changes" styleClass="watchBtn" style="-fx-font-size: 12px; -fx-padding: 8 20;"/>
        </VBox>

        <Separator opacity="0.1" />

        <VBox spacing="15">
            <Label text="Application Settings" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
            
            <CheckBox text="Autoplay next episode" selected="true" style="-fx-text-fill: white;"/>
            <CheckBox text="Email notifications for new releases" style="-fx-text-fill: white;"/>
            <CheckBox text="Hardware Acceleration" selected="true" style="-fx-text-fill: white;"/>
        </VBox>

        <Region prefHeight="50"/>
    </VBox>
</ScrollPane>