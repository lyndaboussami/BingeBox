<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.*?>
<?import javafx.geometry.*?>

<StackPane fx:id="playerRoot" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="groupna.projectNetflix.controllers.VideoPlayerController">
    
    <MediaView fx:id="mediaView" preserveRatio="true" />

	<HBox alignment="TOP_LEFT" pickOnBounds="false">
        <padding><Insets top="30" left="30"/></padding>
        <Button text="← Back" onAction="#handleClosePlayer" 
                style="-fx-background-color: rgba(0,0,0,0.5); -fx-text-fill: white; -fx-font-size: 18px; -fx-cursor: hand; -fx-background-radius: 20;"/>
    </HBox>
    
    <VBox fx:id="controlsBox" alignment="BOTTOM_CENTER" spacing="10" style="-fx-background-color: rgba(0,0,0,0.7); -fx-padding: 15;">
        <StackPane.margin>
            <Insets top="400"/> 
        </StackPane.margin>
        
        <Slider fx:id="progressBar" style="-fx-cursor: hand;"/>
        
        <HBox spacing="20" alignment="CENTER">
            <Button text="⟲ 10s" onAction="#rewind" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button fx:id="playPauseBtn" text="⏸" onAction="#togglePlay" prefWidth="50" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;"/>
            <Button text="10s ⟳" onAction="#forward" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label fx:id="timeLabel" text="00:00 / 00:00" style="-fx-text-fill: white;" />
            <Region HBox.hgrow="ALWAYS" />
            
            <Label text="Vol:" style="-fx-text-fill: white;" />
            <Slider fx:id="volumeSlider" prefWidth="100" />
            <Button text="⛶" onAction="#toggleFullScreen" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px;"/>
        </HBox>
    </VBox>
	<VBox fx:id="nextEpisodeOverlay" visible="false" alignment="CENTER" spacing="15" 
	      style="-fx-background-color: rgba(0,0,0,0.85);">
	    <Label text="Up Next" style="-fx-text-fill: white; -fx-font-size: 24px;"/>
	    <Label fx:id="countdownLabel" text="10" style="-fx-text-fill: #E50914; -fx-font-size: 50px; -fx-font-weight: bold;"/>
	    <HBox alignment="CENTER" spacing="15">
	        <Button text="Play Now" onAction="#playNextImmediately" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-padding: 10 20;"/>
	        <Button text="Cancel" onAction="#cancelAutoPlay" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white;"/>
	    </HBox>
	</VBox>
	<VBox fx:id="nextEpisodeOverlay" visible="false" alignment="CENTER" spacing="15" 
	      style="-fx-background-color: rgba(0,0,0,0.9);">
	    <Label text="Next Episode Starting In..." style="-fx-text-fill: white; -fx-font-size: 20px;"/>
	    <Label fx:id="countdownLabel" text="10" style="-fx-text-fill: #b0a596; -fx-font-size: 60px; -fx-font-weight: bold;"/>
	    <HBox alignment="CENTER" spacing="20">
	        <Button text="Play Now" onAction="#playNextImmediately" 
	                style="-fx-background-color: #b0a596; -fx-text-fill: #111522; -fx-padding: 10 20;"/>
	        <Button text="Cancel" onAction="#cancelAutoPlay" 
	                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-padding: 10 20;"/>
	    </HBox>
	</VBox>
</StackPane>